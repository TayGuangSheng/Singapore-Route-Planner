ONEMAP_EMAIL=YOUR_REGISTERED_ONEMAP_EMAIL
ONEMAP_EMAIL_PASSWORD=YOUR_ONEMAP_PASSWORD
ONEMAP_API_TOKEN=

# Google AdMob banner ads for native Capacitor builds.
# Leave these blank to use Google's test banner IDs while developing.
VITE_ADMOB_ANDROID_BANNER_ID=
VITE_ADMOB_IOS_BANNER_ID=
VITE_ADMOB_USE_TEST_ADS=true
VITE_ADMOB_ENABLED=true

# Android native app ID. Used by android/app/build.gradle.
ADMOB_ANDROID_APP_ID=ca-app-pub-3940256099942544~3347511713
